    "    if v > 100: \n",
    "        alertas.append(v)\n",
    "\n",
    "if len(alertas) == 0:\n",
    "    print(\"Sistema seguro\")\n",
    "else:\n",
    "    print(f\"Revisar valores: {alertas}\")"
